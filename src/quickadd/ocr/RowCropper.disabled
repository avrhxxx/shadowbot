import sharp from "sharp";
import { RowBoundingBox } from "./RowDetector";

export class RowCropper {
  static async crop(buffer: Buffer, boxes: RowBoundingBox[]): Promise<Buffer[]> {
    const crops: Buffer[] = [];
    for (const box of boxes) {
      const crop = await sharp(buffer)
        .extract({ left: box.left, top: box.top, width: box.right - box.left, height: box.bottom - box.top })
        .toBuffer();
      crops.push(crop);
    }
    return crops;
  }
}
